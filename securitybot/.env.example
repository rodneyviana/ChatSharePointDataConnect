# rename site to .env
# SecurityBot Environment Configuration
# Choose ONE of the following AI provider configurations:

# ============================================================================
# Option 1: Ollama (Recommended - Local, Free, Privacy-focused)
# ============================================================================
# MODELID should be the name of your Ollama model (e.g., "llama3.2", "qwen2.5")
# ENDPOINT should be "http://localhost:11434/v1" (note the /v1 suffix for OpenAI compatibility)
# APIKEY can be any dummy value like "ollama" (Ollama doesn't use API keys)

MODELID="llama3.2"
ENDPOINT="http://localhost:11434/v1"
APIKEY="ollama"
CONNECTIONSTRING="Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=SPGraphConnector;Integrated Security=True;Connect Timeout=30;Encrypt=False;"

# ============================================================================
# Option 2: OpenAI API (Cloud, Pay-per-Use)
# ============================================================================
# MODELID="gpt-4o"
# ENDPOINT="https://api.openai.com/v1"
# APIKEY="sk-your-openai-api-key-here"
# CONNECTIONSTRING="Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=SPGraphConnector;Integrated Security=True;Connect Timeout=30;Encrypt=False;"

# ============================================================================
# Option 3: Azure OpenAI (Enterprise Cloud)
# ============================================================================
# MODELID="your-deployment-name"
# ENDPOINT="https://your-resource.openai.azure.com/"
# APIKEY="your-azure-openai-api-key"
# CONNECTIONSTRING="Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=SPGraphConnector;Integrated Security=True;Connect Timeout=30;Encrypt=False;"
